{
  "functions": {
    "api/tts.js": {
      "maxDuration": 30
    },
    "api/image.js": {
      "maxDuration": 60
    },
    "api/script.js": {
      "maxDuration": 60
    },
    "api/youtube-token.js": {
      "maxDuration": 15
    },
    "api/telegram.js": {
      "maxDuration": 15
    }
  },
  "buildCommand": "npm run build",
  "outputDirectory": "public",
  "headers": [
    {
      "source": "/vendor/core/esm/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    },
    {
      "source": "/vendor/ffmpeg/esm/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    },
    {
      "source": "/vendor/util/esm/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    }
  ]
}