{
  "functions": {
    "api/tts.js": {
      "maxDuration": 30
    },
    "api/image.js": {
      "maxDuration": 60
    },
    "api/script.js": {
      "maxDuration": 60
    },
    "api/youtube-token.js": {
      "maxDuration": 15
    },
    "api/telegram.js": {
      "maxDuration": 15
    }
  },
  "headers": [
    {
      "source": "/vendor/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
